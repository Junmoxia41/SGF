# --- Builds del proyecto ---
# server/dist/ y client/dist/ se generan al ejecutar instalar-todo.bat.
# NO se commitean: cada instalacion los regenera desde src/.
server/dist/
client/dist/

# --- Datos de runtime (BD local SQLite, etc.) ---
server-data/
*.db
*.sqlite
*.sqlite3
*.db-journal
*.db-wal
*.db-shm

# --- Entorno / secretos ---
server/.env
server/.env.local
client/.env
client/.env.local
.env
.env.local
*.pem
*.key
secrets/

# --- Editores / OS ---
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db
desktop.ini
$RECYCLE.BIN/

# --- Logs ---
*.log
logs/
launcher-logs/

