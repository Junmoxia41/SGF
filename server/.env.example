# SGF v4.0 - PLANTILLA DE CONFIGURACION
# Copie este archivo como .env y complete los valores reales.
# El archivo .env NO debe commitearse al repositorio.

# === Servidor HTTP ===
PORT=3000
HOST=0.0.0.0

# === Motor de BD ===
# Define que motor usar al arrancar. Opciones:
#   "" (vacio)  -> intenta Oracle -> SQL Server -> SQLite (fallback)
#   "oracle"    -> solo Oracle, falla si no esta
#   "mssql"     -> solo Microsoft SQL Server, falla si no esta
#   "sqlite"    -> solo SQLite local (modo desarrollo)
DB_TYPE=

# === Oracle (BD objetivo principal, historico del proyecto) ===
ORACLE_USER=pcelular
ORACLE_PASSWORD=CAMBIAR_EN_INSTALACION
ORACLE_HOST=127.0.0.1
ORACLE_PORT=1521
ORACLE_SERVICE=PCELULAR

# === Pool Oracle ===
ORACLE_POOL_MIN=2
ORACLE_POOL_MAX=20
ORACLE_POOL_INCREMENT=2
ORACLE_POOL_TIMEOUT=60

# === Microsoft SQL Server ===
# Driver: mssql (que envuelve tedious). Multiplataforma, sin binarios nativos.
# Los parametros encrypt=true se usan en Azure; trustServerCertificate=true
# en LAN con certificados autofirmados.
MSSQL_USER=sa
MSSQL_PASSWORD=CAMBIAR_EN_INSTALACION
MSSQL_SERVER=localhost
MSSQL_PORT=1433
MSSQL_DATABASE=sgf
MSSQL_ENCRYPT=false
MSSQL_TRUST_CERT=true
MSSQL_POOL_MIN=0
MSSQL_POOL_MAX=10
MSSQL_POOL_IDLE_MS=30000

# === JWT ===
# IMPORTANTE: genere un secreto aleatorio largo, por ejemplo:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CAMBIAR_POR_SECRETO_ALEATORIO
JWT_EXPIRES_IN=8h

# === Limites ===
REQUEST_TIMEOUT_MS=30000
MAX_FILE_SIZE_MB=10

# === Rate limiting de login (opcional) ===
# Numero maximo de intentos de login por IP+usuario en 1 minuto.
LOGIN_RATE_PER_MIN=5
# Numero maximo de intentos en 15 minutos.
LOGIN_RATE_PER_15MIN=30

# === Confianza en X-Forwarded-For (opcional) ===
# Por defecto (vacio o ausente): la IP del socket TCP es la que se registra
# en SGF_LOGS. Esto es lo correcto en una LAN sin proxy reverso.
# Solo active esto si tiene un proxy reverso (Nginx, Apache, Caddy, etc.)
# delante del servidor SGF.
#   TRUST_PROXY=1   -> toma la primera IP de X-Forwarded-For
#   TRUST_PROXY=2   -> toma la penultima (util con varios proxies)
TRUST_PROXY=
